#!/usr/bin/env bash
# Codex wrapper: auto-convert session to Claude format on exit
# Usage: codex-with-sync [normal codex args]

# Run codex normally
codex "$@"
CODEX_EXIT=$?

# After codex exits, find the latest session and convert it
# Get session ID from codex history (last entry)
SESSION_ID=$(tail -1 ~/.codex/history.jsonl 2>/dev/null | python3 -c "import sys, json; print(json.load(sys.stdin).get('session_id', ''))" 2>/dev/null || true)

if [ -n "$SESSION_ID" ]; then
    python3 ~/claude-utils/codex-to-claude.py "$SESSION_ID" > /tmp/codex-to-claude-hook.log 2>&1 || true
fi

exit $CODEX_EXIT
